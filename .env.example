# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Security Configuration
VITE_ADMIN_EMAIL=cybersafeadmin@deepcytes.uk.in
VITE_JWT_SECRET=your_jwt_secret_key
VITE_ENCRYPTION_KEY=your_encryption_key

# API Configuration
VITE_API_BASE_URL=https://api.cybersafe.gov.in
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW=60000

# Security Headers
VITE_CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
VITE_HSTS_MAX_AGE=31536000